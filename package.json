{
  "name": "offgridos",
  "version": "0.1.0",
  "description": "Off-grid solar system design tool",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "build:web": "vite build",
    "bdd": "node --import tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js --import features/step_definitions/**/*.ts features/**/*.feature",
    "dev": "tsx",
    "dev:app": "node scripts/dev-app.mjs",
    "publish:db": "tsx scripts/publish-db.ts",
    "stop:app": "node scripts/stop-app.mjs",
    "test:e2e": "npm run build && playwright test",
    "start": "node scripts/start-app.mjs",
    "start:server": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^9.6.0",
    "chalk": "^5.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.21",
    "vitest": "^2.0.0"
  }
}
